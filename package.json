{
  "name": "action-update-posts",
  "version": "0.0.4",
  "repository": "git@github.com:TryGhost/action-update-posts.git",
  "author": "Ghost Foundation",
  "license": "MIT",
  "type": "module",
  "main": "index.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "ncc build",
    "lint": "eslint . --cache",
    "test": "vitest run --coverage",
    "preship": "yarn build && yarn lint && yarn test",
    "ship": "STATUS=$(git status --porcelain); echo $STATUS; if [ -z \"$STATUS\" ]; then yarn version && git push --follow-tags; fi"
  },
  "files": [
    "index.js",
    "lib"
  ],
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@vercel/ncc": "0.44.0",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.5.0",
    "eslint-plugin-ghost": "3.5.0",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@tryghost/admin-api": "1.14.10"
  }
}
