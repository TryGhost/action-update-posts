{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "env": {
    "node": true,
    "es2024": true
  },
  "ignorePatterns": [
    "dist/**"
  ],
  "rules": {
    "no-console": "error"
  },
  "overrides": [
    {
      "files": [
        "index.js"
      ],
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": [
        "*.test.mjs"
      ],
      "env": {
        "vitest": true
      }
    }
  ]
}
